# =============================================================
# 公众号文章编写项目编排 —— .gitignore
# =============================================================

# ---- 敏感配置 / 凭据 ----
# 含 Claude 与 Gemini 密钥，绝不提交
.claude/settings.local.json

# ---- 个人写作风格参考（个人隐私，不提交）----
# reference 目录下全部忽略，仅保留通用合规规范
.claude/reference/*
!.claude/reference/公众号合规规范.md

# ---- 文章工作区（articles/）：保留 ----
# 不忽略 articles/。文章工作区（含 articles/CLAUDE.md 规则文件、各篇 14 产物、
# 样本文章）均纳入版本，供克隆者参考完整流程。
# 如需忽略某篇具体文章的工作产物，可在此按标题单独添加，例如：
# articles/某篇文章标题/

# ---- 文章最终交付（成品内容，不提交）----
# 每篇定稿 + 配图；这里以样本为例
AI时代，普通人到底该不该焦虑被淘汰？/

# ---- Python 构建产物（图片生成脚本运行时产生）----
__pycache__/
*.py[cod]
generated_images/
