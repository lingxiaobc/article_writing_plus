# =============================================================
# 公众号文章编写项目编排 —— .gitignore
# =============================================================

# ---- 敏感配置 / 凭据 ----
# 含 Claude 与 Gemini 密钥，绝不提交
.claude/settings.local.json

# ---- 个人写作风格参考（个人隐私，不提交）----
# reference 目录下全部忽略，仅保留通用合规规范
.claude/reference/*
!.claude/reference/公众号合规规范.md

# ---- 文章工作区（articles/）：默认不提交，仅保留样本与规则文件 ----
# 忽略 articles/ 下所有内容（各篇 14 产物工作区），但保留：
#   - AI时代… 样本文章（供克隆者参考完整流程）
#   - articles/CLAUDE.md（工作区结构规则文件）
# 注意：必须用 articles/*（而非 articles/），否则无法用 ! 重新包含子项。
articles/*
!articles/AI时代，普通人到底该不该焦虑被淘汰？/
!articles/CLAUDE.md
.claude/active-article

# ---- 文章最终交付（成品内容，不提交）----
# 每篇定稿 + 配图；这里以样本为例
# 注意：前导 / 锚定到仓库根目录，避免误伤 articles/ 下的同名样本目录
/AI时代，普通人到底该不该焦虑被淘汰？/

# ---- 待发布文章暂存（成品内容，不提交）----
/pending_articles/

# ---- Python 构建产物（图片生成脚本运行时产生）----
__pycache__/
*.py[cod]
generated_images/
